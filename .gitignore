# dependencies / build artifacts
node_modules/
dist/
*.tsbuildinfo
*.log

# Analysis target projects stay local and are never published — including the
# demo fixtures. The whole checkout area is ignored.
/.repo/

# Analysis outputs (graphs / join / screens / impact JSON). Now per-service:
# <OUT_DIR>/<service>/graph.*.json (+ graph.impact/ shards) — ignore the whole
# service tree, keep tracked docs like json/README.md.
/json/*.json
/json/*/

# --- 머신별 실행 설정(real). 템플릿 flowmap.config.example 만 추적 ---
/flowmap.config

