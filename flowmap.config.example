# flowmap.config — flowmap-react(프론트 분석기) 실행 설정.
#   `./flowmap pipeline` 과 scripts/pipeline/NN-*.sh 가 이 파일을 읽는다.
# 사용법: 이 파일을 `flowmap.config` 로 복사한 뒤 값을 채운다.
#   real(flowmap.config) 은 머신별 설정이라 .gitignore 대상이고, 템플릿(flowmap.config.example)만 추적된다.
# 형식: KEY=VALUE, '#' 주석, ${VAR}/$VAR 치환(앞 키 → 환경변수 순).

# ───────────── 필수 (required) ─────────────
# 분석 대상 소스 체크아웃 루트 (.repo/<project>/ 관례)
REPO=.repo

# 백엔드 결합 그래프 (join 단계 입력). 없거나 파일이 없으면 join 은 건너뜀.
# CSV 로 여러 백엔드 지정 가능 — join 이 모든 백엔드의 컨트롤러/alias 를 한 인덱스로 합쳐 매칭.
# (nexcore .jmd 트랜잭션은 /std·/lng 등 프리픽스 호출을 alias[Tid] 로 매칭)
BACKEND=../flowmap-spring/json/_combined.json,../flowmap-nexcore/json/_combined.json

# ───────────── 선택 (optional) ─────────────
# PROJECT=fe-service-workspace   # 미지정 시 REPO(.repo) 아래 모든 프로젝트를 한 번에 분석
# NAME=graph                     # 출력 파일명 베이스 (없으면 PROJECT, 그것도 없으면 graph)
# OUT_DIR=json/frontend          # 결과 JSON 디렉터리 — <OUT_DIR>/<service>/<NAME>.{json,screens,join,impact}.json
# MODE=development               # Vue/Nuxt env 선택 (development|production). React 는 무시
# PULL=true                      # 분석 전 git pull --ff-only (true/false). 로컬 샘플은 false
# ENV_PROFILE=sandbox            # 모노레포 env-cmd(.env-cmdrc.json) 프로파일 — API 게이트웨이 host 해석
# AFFINITY=flowmap.affinity.json # frontend svc ↔ backend project 힌트(JSON). 같은 REST path 를 여러 백엔드가
#                                #   제공해 ambiguous(=false external)로 빠질 때, 그 프론트 서비스가 실제로 쓰는
#                                #   백엔드 project 로 후보를 좁혀 matched 로 만든다. 형식:
#                                #     { "services-account": ["account*","isa*"], "services-stock": ["supernova*"] }
#                                #   키=프론트 서비스명 glob(graph meta.project), 값=백엔드 project glob 목록.
#                                #   (`{ "affinity": { ... } }` 처럼 affinity 키 아래 중첩해도 됨)
# --- 대용량 저장소 메모리 튜닝 ---
# ENV=path/to/app.env            # 앱 env 파일(--env): KEY=VALUE 직접 주입(가장 확실한 host 주입 수단)
# WORKERS=4                      # 동시 자식 프로세스 수
# MAX_OLD_SPACE=12288            # 프로세스당 V8 힙(MB)
# NO_SPLIT=false                 # true 면 분할 끄고 단일 프로세스
